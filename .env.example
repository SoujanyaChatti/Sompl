# FeatureDNA — environment variables
# The app runs fully WITHOUT any of these (demo-safe fallbacks).
# Add keys to light up real AI + analytics + persistence.

# ── Groq (free tier) — powers Smart Commit parsing + AI Historian ──────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
# ── Novus.ai — MANDATORY analytics for the hackathon ───────────────────────
# Project key from your Novus dashboard. Without it, activity is still
# mirrored locally and shown in the in-app Activity panel.
NEXT_PUBLIC_NOVUS_KEY=

# ── Supabase (optional) — Auth + Postgres persistence ──────────────────────
# Create a project at https://supabase.com and run supabase/schema.sql
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
